# tiller ambient policy. Input schema: ToolCallRequest.
# Applied when TILLER_ROLE is unset (not inside a managed run) but
# the active main-session model is in the reason tier. Enforces orchestrator-only
# capability: the root reason-tier agent may read and dispatch (Agent/TodoWrite),
# but may not directly edit, write, or execute.

segment denied_tools {
    tool.name in ["Edit", "Write", "NotebookEdit", "Bash", "apply_patch", "exec_command", "write_stdin"]
}

rule HaltAmbient priority 0 {
    kill_switch
    when { true }
    then Deny { reason: "tiller ambient halt" }
}

rule AllowRead priority 10 {
    when {
        tool.name in [
            "Read",
            "Glob",
            "Grep",
            "view_image",
            "WebFetch",
            "WebSearch",
            "ToolSearch",
            "tool_search_tool",
            "list_mcp_resources",
            "list_mcp_resource_templates",
            "read_mcp_resource",
            "get_goal"
        ]
    }
    then Allow { reason: "read/context gathering is permitted for the ambient orchestrator" }
}

rule AllowAgent priority 10 {
    when { tool.name in ["Agent", "Task"] }
    then Allow { reason: "reason-tier orchestrator dispatches via Agent (Task); subagents execute" }
}

rule AllowTodoWrite priority 10 {
    when { tool.name == "TodoWrite" }
    then Allow { reason: "todo management is permitted for planning" }
}

# Gap 1: orchestration tools that the ambient orchestrator needs.
# Skill, AskUserQuestion, EnterPlanMode,
# ExitPlanMode are orchestration-shaped and must be allowed at the same tier.
# The Task-tracking family (TaskCreate / TaskGet / TaskList / TaskUpdate /
# TaskOutput / TaskStop) lets the orchestrator manage in-flight work items;
# "Task" (the Claude Code subagent spawner) is already allowed by AllowAgent
# above. Codex multi-agent tool names are included in both bare and hook
# matcher-concatenated namespace forms.
rule AllowOrchestrationTools priority 10 {
    when {
        tool.name in [
            "Skill",
            "AskUserQuestion",
            "EnterPlanMode",
            "ExitPlanMode",
            "TaskCreate",
            "TaskGet",
            "TaskList",
            "TaskUpdate",
            "TaskOutput",
            "TaskStop",
            "spawn_agent",
            "spawn_agents_on_csv",
            "send_input",
            "resume_agent",
            "wait_agent",
            "close_agent",
            "multi_agent_v1spawn_agent",
            "multi_agent_v1spawn_agents_on_csv",
            "multi_agent_v1send_input",
            "multi_agent_v1resume_agent",
            "multi_agent_v1wait_agent",
            "multi_agent_v1close_agent",
            "update_plan",
            "request_user_input",
            "create_goal",
            "update_goal"
        ]
    }
    then Allow { reason: "orchestration tools are permitted for the ambient orchestrator" }
}

# Gap 2: confinement rules for Task/Agent subagent model selection.
# These fire BEFORE the AllowAgent allow (higher priority = lower number).
#
# DenyReasonModelSubagent — blocks Task/Agent calls that carry an explicit
# reason-tier model override for persona types that should use cheaper tiers.
# tiller-architect, tiller-deep-report, tiller-investigator, and
# tiller-reviewer are permitted to use reason-tier overrides. Execution personas
# must stay below reason tier.
rule DenyReasonModelSubagent priority 8 {
    when {
        tool.name in ["Task", "Agent"] and
        tool.agent_model_tier == "reason" and
        tool.agent_type not in ["tiller-architect", "tiller-deep-report", "tiller-investigator", "tiller-reviewer"]
    }
    then Deny { reason: "tiller: reason-tier model overrides are reserved for design, research, investigation, and review personas. Execution work → tiller-worker or tiller-debugger on a non-reason model. Remove the model override or select the appropriate tiller-* persona." }
}

# DenyImplicitReasonInheritance — blocks Task/Agent calls with a generic
# subagent type and no explicit model field.  In an ambient reason-tier
# session these generic agents inherit the parent (reason-tier) model, which
# wastes budget.  The orchestrator must either pass an explicit cheaper model
# or use a named tiller-* persona whose frontmatter pins the model.
rule DenyImplicitReasonInheritance priority 9 {
    when {
        tool.name in ["Task", "Agent"] and
        tool.agent_type in ["general-purpose", "claude", "Explore", "Plan", ""] and
        tool.agent_model_tier == ""
    }
    then Deny { reason: "tiller: generic subagent types inherit the ambient reason-tier model when no explicit model is provided. Pass an explicit cheaper model or use a named tiller-* persona (tiller-scout, tiller-summary, tiller-worker, tiller-debugger, tiller-investigator, tiller-reviewer, tiller-architect, tiller-deep-report) whose frontmatter pins the model." }
}

# DenyHyphaDaemons — defense-in-depth: even if a future classifier change
# inadvertently reclassifies "hypha mcp serve" as readonly, this explicit deny
# fires first (priority 14 < 15) and produces a clear audit line.
# Mirrors toolgate's DenyHyphaDaemons (org-wide prohibition on per-session daemons).
rule DenyHyphaDaemons priority 14 {
    when {
        (tool.name == "Bash") and
        (tool.command matches "hypha +(mcp|hub) +serve")
    }
    then Deny { reason: "persistent hypha daemons are forbidden (22GB OOM incident)" }
}

# AllowPermittedBash — allows the ambient orchestrator to run Bash commands
# that carry an explicitly permitted command class:
#
#   "readonly"       — read-only commands (git log, ls, cat, gts, hypha recall,
#                      …).  The Go-side ClassifyCommand classifier sets this class
#                      only when every pipeline segment is in the read-only
#                      allowlist and no dangerous redirects/substitutions appear.
#                      "2>&1" is the one permitted redirect token.
#
#   "self-uninstall" — escape hatch for "tiller uninstall [--print] [--project]".
#                      The Go-side IsSelfUninstall predicate (quote-aware tokenizer,
#                      single-segment check, argv validation) sets this class.  The
#                      class is intentionally distinct from "readonly" because
#                      uninstall mutates settings.json; the classifier must stay
#                      honest.
#
#   "ambient-control" — temporary testing/control commands:
#                      "tiller ambient disable|enable|status|next|step --dry-run|doctor".
#
#   "codex-exec"    — constrained Codex CLI delegation:
#                      explicit gpt-5.5, explicit model_reasoning_effort,
#                      xhigh only with read-only sandboxing, high/medium for
#                      execution, optional report output under .tiller/, and
#                      no dangerous sandbox bypass flags.
#
# These classes are combined in one rule to avoid an arbiter v1.8.0 VM
# quirk: having two separate inline-condition rules before a segment-based rule
# causes the segment rule to not evaluate.  A single OR condition is the
# correct workaround.
rule AllowPermittedBash priority 15 {
    when {
        (tool.name in ["Bash", "exec_command"]) and
        (tool.command_class == "readonly" or tool.command_class == "self-uninstall" or tool.command_class == "ambient-control" or tool.command_class == "codex-exec")
    }
    then Allow { reason: "Bash command permitted for the ambient orchestrator (class: {tool.command_class})" }
}

# AllowMarkdownAuthoring — allows the ambient orchestrator to Write or Edit
# markdown files (specs, plans, prompts, directives, briefs, code-in-specs).
# Only .md paths are permitted; code files, notebooks, and no-extension paths
# remain denied by DenyExecution below.
rule AllowMarkdownAuthoring priority 15 {
    when {
        tool.name in ["Write", "Edit"] and
        tool.file_path ends_with ".md"
    }
    then Allow { reason: "markdown authoring (specs, plans, prompts, directives) is permitted for the ambient orchestrator" }
}

rule DenyExecution priority 20 {
    when segment denied_tools { true }
    then Deny { reason: "tiller: ambient orchestrator runs in read/dispatch mode — delegate with the Task tool: status compaction → tiller-summary, code changes → tiller-worker, debugging → tiller-debugger, investigation → tiller-investigator, review → tiller-reviewer; reserve tiller-architect/tiller-deep-report for deep design and research. {tool.name} is not permitted for the root orchestrator agent." }
}
