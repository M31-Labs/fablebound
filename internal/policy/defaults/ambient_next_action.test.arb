test "over budget halts" {
    given {
        run.status: "running"
        run.reason_budget_used: 0
        run.reason_budget: 2
        run.output_budget_band: "over"
        run.reasoning_budget_band: "ok"
        work.pending_descriptor_count: 1
        work.failed_descriptor_count: 1
        work.pending_agent_count: 1
        work.stale_agent_count: 1
        work.failed_agent_count: 1
        work.iteration_count: 4
        distillation.available: true
        distillation.count: 2
        distillation.age_seconds: 60
        distillation.status: "fresh"
        checkpoint.fresh_count: 1
        checkpoint.proposed_count: 1
        checkpoint.late_count: 1
        checkpoint.conflicting_count: 1
        checkpoint.has_verification: true
        risk.changed_files_count: 3
        risk.touches_policy: true
        risk.touches_sandbox: true
    }
    expect strategy AmbientNextAction selected Halt { action: "halt", budget_posture: "over" }
}

