# Tests for ambient_next_action.arb.

test "fresh verified candidate checkpoints" {
    given {
        run.status: "running"
        run.reason_budget_used: 0
        run.reason_budget: 2
        run.output_budget_band: "ok"
        run.reasoning_budget_band: "ok"
        work.pending_descriptor_count: 0
        work.failed_descriptor_count: 0
        work.pending_agent_count: 0
        work.stale_agent_count: 0
        work.failed_agent_count: 0
        work.iteration_count: 1
        distillation.available: true
        distillation.count: 1
        distillation.age_seconds: 120
        distillation.status: "fresh"
        checkpoint.fresh_count: 1
        checkpoint.proposed_count: 0
        checkpoint.late_count: 0
        checkpoint.conflicting_count: 0
        checkpoint.has_verification: true
        risk.changed_files_count: 2
        risk.touches_policy: false
        risk.touches_sandbox: false
    }
    expect strategy AmbientNextAction selected Checkpoint { action: "checkpoint", target: "checkpoint" }
}

