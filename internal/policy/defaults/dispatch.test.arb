# Tests for dispatch.arb — tiller dispatch gate.
#
# Canonical tier combos (flat defaults):
#   orchestrator → reason   chief-architect → reason   deep-report → reason
#   investigator → scrutiny  reviewer        → scrutiny
#   worker       → execute   debugger        → execute
#
# Coverage targets: every rule (HaltAll, DenyReasonTierForExecution,
# DenyReasonFromNonRoot, DenyTerminalDepth, DenyReasonBudget,
# DenyConcurrencyCap, DenyExecutionSpawnsInsight, DenyReviewerDispatch,
# DenyInvestigatorScope, DenyInsightScope, DenyWorkerScope, AllowDispatch)
# and every DispatchRoute strategy arm (Architect, DeepReport,
# Investigator, Worker, Debugger, Reviewer).

# ── Baseline allow paths ────────────────────────────────────────────────────

test "worker dispatch by orchestrator at depth 0 is allowed" {
    given {
        dispatch.role: "worker"
        dispatch.tier: "execute"
        dispatch.background: false
        dispatch.brief_bytes: 512
        caller.role: "orchestrator"
        caller.depth: 0
        caller.dispatch_id: "root"
        run.id: "20260101-000000-0001"
        run.active_dispatches: 0
        run.reason_dispatches: 0
        run.reason_budget: 2
    }
    expect rule AllowDispatch matched
    expect rule DenyReasonTierForExecution not matched
    expect rule DenyTerminalDepth not matched
}

