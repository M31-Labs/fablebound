test "fable+worker triggers DenyFableForExecution (combined)" {
    given {
        dispatch.role: "worker"
        dispatch.model: "fable"
        dispatch.background: false
        dispatch.brief_bytes: 100
        caller.role: "orchestrator"
        caller.depth: 0
        caller.dispatch_id: "root"
        run.id: "20260101-000000-0001"
        run.active_dispatches: 0
        run.fable_dispatches: 0
        run.fable_budget: 2
    }
    # DenyFableForExecution (priority 1) wins over AllowDispatch (priority 99)
    expect rule DenyFableForExecution matched
}

test "orchestrator dispatching chief-architect with budget remaining is fully allowed" {
    given {
        dispatch.role: "chief-architect"
        dispatch.model: "fable"
        dispatch.background: false
        dispatch.brief_bytes: 2048
        caller.role: "orchestrator"
        caller.depth: 0
        caller.dispatch_id: "root"
        run.id: "20260101-000000-0001"
        run.active_dispatches: 1
        run.fable_dispatches: 1
        run.fable_budget: 2
    }
    expect rule AllowDispatch matched
    expect rule DenyFableForExecution not matched
    expect rule DenyFableFromNonRoot not matched
    expect rule DenyFableBudget not matched
    expect rule DenyTerminalDepth not matched
    expect strategy DispatchRoute selected Architect
}

