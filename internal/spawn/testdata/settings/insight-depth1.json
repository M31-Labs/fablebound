{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "tiller hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "tiller hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(tiller *)",
      "Bash(hypha *)"
    ],
    "ask": [],
    "deny": [
      "Edit",
      "Write",
      "NotebookEdit",
      "Agent",
      "WebFetch",
      "WebSearch"
    ]
  }
}