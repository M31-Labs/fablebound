# tiller ambient policy. Input schema: ToolCallRequest.
# Applied when TILLER_ROLE is unset (not inside a managed run) but
# the active main-session model is in the reason tier. Enforces orchestrator-only
# capability: the root reason-tier agent may read and dispatch (Agent/TodoWrite),
# but may not directly edit, write, or execute.

segment denied_tools {
    tool.name in ["Edit", "Write", "NotebookEdit", "Bash"]
}

rule HaltAmbient priority 0 {
    kill_switch
    when { true }
    then Deny { reason: "tiller ambient halt" }
}

rule AllowRead priority 10 {
    when { tool.name in ["Read", "Glob", "Grep"] }
    then Allow { reason: "reading is permitted for the ambient orchestrator" }
}

rule AllowAgent priority 10 {
    when { tool.name in ["Agent", "Task"] }
    then Allow { reason: "reason-tier orchestrator dispatches via Agent (Task); subagents execute" }
}

rule AllowTodoWrite priority 10 {
    when { tool.name == "TodoWrite" }
    then Allow { reason: "todo management is permitted for planning" }
}

rule AllowWebFetch priority 10 {
    when { tool.name == "WebFetch" }
    then Allow { reason: "web reading is permitted for the ambient orchestrator" }
}

# Gap 1: orchestration / harness tools that the ambient orchestrator needs.
# ToolSearch loads deferred tool schemas — without it the orchestrator cannot
# invoke any deferred tool at all.  Skill, AskUserQuestion, EnterPlanMode,
# ExitPlanMode are orchestration-shaped and must be allowed at the same tier.
# The Task-tracking family (TaskCreate / TaskGet / TaskList / TaskUpdate /
# TaskOutput / TaskStop) lets the orchestrator manage in-flight work items;
# "Task" (the subagent spawner) is already allowed by AllowAgent above.
rule AllowOrchestrationTools priority 10 {
    when {
        tool.name in [
            "ToolSearch",
            "Skill",
            "AskUserQuestion",
            "EnterPlanMode",
            "ExitPlanMode",
            "TaskCreate",
            "TaskGet",
            "TaskList",
            "TaskUpdate",
            "TaskOutput",
            "TaskStop"
        ]
    }
    then Allow { reason: "orchestration and harness tools are permitted for the ambient orchestrator" }
}

# Gap 2: confinement rules for Task/Agent subagent model selection.
# These fire BEFORE the AllowAgent allow (higher priority = lower number).
#
# DenyReasonModelSubagent — blocks Task/Agent calls that carry an explicit
# reason-tier model override for persona types that should use cheaper tiers.
# tiller-architect and tiller-deep-report are the only personas legitimately
# operated at the reason tier; all execution/investigation/review personas
# should pin to cheaper models via their frontmatter.
rule DenyReasonModelSubagent priority 8 {
    when {
        tool.name in ["Task", "Agent"] and
        tool.agent_model_tier == "reason" and
        tool.agent_type not in ["tiller-architect", "tiller-deep-report"]
    }
    then Deny { reason: "tiller: reason-tier model overrides are reserved for tiller-architect and tiller-deep-report. Execution work → tiller-worker or tiller-debugger; investigation → tiller-investigator; review → tiller-reviewer. Remove the model override or select the appropriate tiller-* persona." }
}

# DenyImplicitReasonInheritance — blocks Task/Agent calls with a generic
# subagent type and no explicit model field.  In an ambient reason-tier
# session these generic agents inherit the parent (reason-tier) model, which
# wastes budget.  The orchestrator must either pass an explicit cheaper model
# or use a named tiller-* persona whose frontmatter pins the model.
rule DenyImplicitReasonInheritance priority 9 {
    when {
        tool.name in ["Task", "Agent"] and
        tool.agent_type in ["general-purpose", "claude", "Explore", "Plan", ""] and
        tool.agent_model_tier == ""
    }
    then Deny { reason: "tiller: generic subagent types inherit the ambient reason-tier model when no explicit model is provided. Pass an explicit cheaper model or use a named tiller-* persona (tiller-worker, tiller-debugger, tiller-investigator, tiller-reviewer, tiller-architect, tiller-deep-report) whose frontmatter pins the model." }
}

# DenyHyphaDaemons — defense-in-depth: even if a future classifier change
# inadvertently reclassifies "hypha mcp serve" as readonly, this explicit deny
# fires first (priority 14 < 15) and produces a clear audit line.
# Mirrors toolgate's DenyHyphaDaemons (org-wide prohibition on per-session daemons).
rule DenyHyphaDaemons priority 14 {
    when {
        (tool.name == "Bash") and
        (tool.command matches "hypha +(mcp|hub) +serve")
    }
    then Deny { reason: "persistent hypha daemons are forbidden (22GB OOM incident)" }
}

# AllowReadOnlyBash — allows the ambient orchestrator to run read-only Bash
# commands (git log, ls, cat, gts callgraph, hypha recall, …) without forcing
# a round-trip investigator dispatch for trivial lookups.
#
# The Go-side ClassifyCommand classifier splits the command into segments,
# strips env assignments, and checks every argv0+subcommand against the
# read-only allowlist.  Only when every segment classifies as "readonly" does
# the hook set tool.command_class = "readonly".
#
# Redirect/substitution policy: "2>&1" (the exact token) is permitted so that
# the standard pattern "hypha recall '...' 2>&1 | head -80" works correctly.
# Any other >, >>, <, backtick, or $( anywhere → "other".
rule AllowReadOnlyBash priority 15 {
    when {
        (tool.name == "Bash") and
        (tool.command_class == "readonly")
    }
    then Allow { reason: "read-only Bash command permitted for the ambient orchestrator (ls, cat, git log, gts, hypha, …)" }
}

# AllowMarkdownAuthoring — allows the ambient orchestrator to Write or Edit
# markdown files (specs, plans, prompts, directives, briefs) whose content is
# prose-first (not code-dominant).
# Only .md paths are permitted; code files, notebooks, and no-extension paths
# remain denied by DenyExecution below.
# The tool.write_class guard prevents code-dump markdown from slipping through:
# see DenyCodeHeavyMarkdown for the explicit deny.
rule AllowMarkdownAuthoring priority 15 {
    when {
        tool.name in ["Write", "Edit"] and
        tool.file_path ends_with ".md" and
        tool.write_class != "code-heavy"
    }
    then Allow { reason: "markdown authoring (specs, plans, prompts, directives) is permitted for the ambient orchestrator" }
}

# DenyCodeHeavyMarkdown — blocks markdown files whose content is dominated by
# fenced code blocks (>50 fenced lines AND >50% of total lines are fenced).
# The threshold is generous — real specs/plans legitimately embed code snippets.
# Only code-DOMINANT documents are blocked.
# Reason text steers the orchestrator toward the correct delegation pattern
# without naming vendor model tokens.
rule DenyCodeHeavyMarkdown priority 16 {
    when {
        tool.name in ["Write", "Edit"] and
        tool.file_path ends_with ".md" and
        tool.write_class == "code-heavy"
    }
    then Deny { reason: "tiller: code artifacts belong in tiller-worker dispatches — keep orchestrator-authored .md prose-first (specs/plans/prompts/directives). This document is code-dominant (>50 fenced lines, >50% of total). Delegate code generation to tiller-worker via the Task tool." }
}

rule DenyExecution priority 20 {
    when segment denied_tools { true }
    then Deny { reason: "tiller: ambient orchestrator runs in read/dispatch mode — delegate with the Task tool: code changes → tiller-worker, debugging → tiller-debugger, investigation → tiller-investigator, review → tiller-reviewer; reserve tiller-architect/tiller-deep-report for deep design and research. {tool.name} is not permitted for the root orchestrator agent." }
}
