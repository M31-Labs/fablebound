# Tests for ambient.arb — tiller ambient orchestrator-only gate.
# Applied when TILLER_ROLE is unset and the session model is in the reason tier.
# Denied: Edit, Write, NotebookEdit, Bash.
# Allowed: Read, Glob, Grep, Agent, TodoWrite, WebFetch.
# No match → deny (combinator default).
#
# Coverage targets: HaltAmbient (kill_switch), AllowRead, AllowAgent,
# AllowTodoWrite, AllowWebFetch, DenyHyphaDaemons, AllowReadOnlyBash,
# AllowMarkdownAuthoring, DenyCodeHeavyMarkdown, DenyExecution.

# ── AllowRead ────────────────────────────────────────────────────────────────

test "Read is allowed in ambient mode" {
    given {
        agent.role: "ambient-orchestrator"
        agent.depth: 0
        agent.dispatch_id: ""
        tool.name: "Read"
        tool.command: ""
        tool.command_class: ""
        tool.file_path: "/home/user/project/main.go"
        tool.path_in_scratch: false
        tool.path_in_workspace: true
        tool.write_class: ""
        run.id: ""
    }
    expect rule AllowRead matched
    expect rule DenyExecution not matched
}

