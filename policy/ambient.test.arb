# ── Combinator fallthrough — unknown tool is denied ───────────────────────────

test "unknown tool is denied by default (no rule matches)" {
    given {
        agent.role: "ambient-orchestrator"
        agent.depth: 0
        agent.dispatch_id: ""
        tool.name: "SomeUnknownTool"
        tool.command: ""
        tool.command_class: ""
        tool.file_path: ""
        tool.path_in_scratch: false
        tool.path_in_workspace: false
        tool.write_class: ""
        run.id: ""
    }
    expect rule AllowRead not matched
    expect rule AllowAgent not matched
    expect rule AllowTodoWrite not matched
    expect rule AllowWebFetch not matched
    expect rule DenyExecution not matched
}
