# Tests for toolgate.arb — tiller PreToolUse hook gate.
#
# Coverage targets: every rule (HaltAllTools, DenyHyphaDaemons,
# DenyDestructive, DenyTerminalDispatch, OrchestratorRead,
# OrchestratorEffector, OrchestratorDenyRest, ScratchWrite,
# DenyWriteOutsideScratch, ReadOnlyBash, ReadTools, ExecutionAllow).
#
# Roles and segments:
#   orchestrator            → Read/Glob/Grep + tiller/hypha bash only
#   scratch_writers         → chief-architect, deep-report, reviewer
#   readonly_bash_roles     → investigator, reviewer, chief-architect, deep-report
#   execution               → worker, debugger

# ── HaltAllTools (kill_switch) ───────────────────────────────────────────────

test "HaltAllTools kill switch is off by default — bash call proceeds" {
    given {
        agent.role: "worker"
        agent.depth: 1
        agent.dispatch_id: "d01"
        tool.name: "Bash"
        tool.command: "ls /tmp"
        tool.file_path: ""
        tool.path_in_scratch: false
        tool.path_in_workspace: true
        run.id: "20260101-000000-0001"
    }
    expect rule HaltAllTools not matched
}

